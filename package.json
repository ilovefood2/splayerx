{
  "name": "splayer",
  "productName": "splayer",
  "homepage": "https://splayer.org",
  "version": "4.11.51",
  "author": "tomasen <tomasen@gmail.com>",
  "description": "a media player",
  "license": "GPL-3.0-or-later",
  "main": "./dist/electron/main.js",
  "engines": {
    "node": ">=22.12"
  },
  "resolutions": {
    "is-async-function": "2.0.0",
    "is-generator-function": "1.0.10"
  },
  "scripts": {
    "build": "node ./scripts/build.js",
    "build:appx": "cross-env ENVIRONMENT_NAME=APPX ./scripts/build-win.bat appx",
    "build:mas": "scripts/build-mac.sh mas",
    "build:mas-dev": "scripts/build-mac.sh mas-dev",
    "build:clean": "cross-env BUILD_TARGET=clean node .electron-vue/build.js",
    "start": "npm run stage",
    "dev": "cross-env SAGI_API=sagi-api:8443 node .electron-vue/dev-runner.js",
    "stage": "node .electron-vue/dev-runner.js",
    "install-app-deps": "electron-builder install-app-deps",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "pack": "npm run pack:main && npm run pack:renderer && npm run pack:web",
    "pack:main": "cross-env NODE_ENV=production webpack --progress --color --config .electron-vue/webpack.main.config.js",
    "pack:renderer": "cross-env NODE_ENV=production webpack --progress --color --config .electron-vue/webpack.renderer.config.js",
    "pack:web": "cross-env NODE_ENV=production webpack --progress --color --config .electron-vue/webpack.web.config.js",
    "test": "npm run unit",
    "unit": "vitest run",
    "unit:watch": "vitest",
    "unit:coverage": "vitest run --coverage",
    "postinstall": "node ./scripts/post-install.js",
    "prepare:mac": "scripts/bundle-llama.sh && scripts/bundle-whisper.sh && node node_modules/ffmpeg-ffprobe-static/install.js && node scripts/gen-electron-builder-config.js",
    "pack:mac": "npm run pack && npm run prepare:mac && cross-env USE_HARD_LINKS=false CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir --arm64 -p never -c.mac.hardenedRuntime=false"
  },
  "_moduleAliases": {
    "electron": "node_modules/electron",
    "grpc": "node_modules/@grpc/grpc-js"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.4",
    "@sentry/electron": "7.15.0",
    "@sentry/vue": "10.62.0",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/core": "2.6.0",
    "@splayer/ass-compiler": "0.0.11-dev.1",
    "@splayer/electron-json-storage": "4.1.6",
    "@splayer/subtitle": "2.0.3",
    "@splayer/youtube-dl": "2.3.4",
    "chardet": "^0.7.0",
    "configcat-js": "^2.0.0",
    "configcat-node": "^3.0.3",
    "electron-log": "5.4.4",
    "electron-updater": "6.8.9",
    "filesize": "^6.0.1",
    "franc": "^4.0.0",
    "fs-extra": "^7.0.1",
    "get-video-id": "^3.1.4",
    "google-protobuf": "^3.6.0",
    "html-to-image": "^0.1.1",
    "iconv-lite": "^0.4.24",
    "idb": "^4.0.3",
    "lethargy": "^1.0.4",
    "libphonenumber-js": "^1.7.24",
    "lodash": "^4.17.19",
    "lottie-web": "^5.5.4",
    "nzh": "^1.0.4",
    "os-locale": "^3.0.1",
    "p-queue": "^6.0.0",
    "parse": "^2.9.1",
    "regedit": "3.0.3",
    "romanize": "^1.1.1",
    "sagi-api": "0.0.20",
    "traditional-or-simplified": "^1.0.3",
    "url-parse-lax": "^3.0.0",
    "uuid": "14.0.1",
    "@vue/compat": "3.5.40",
    "vue": "3.5.40",
    "vue-i18n": "11.4.6",
    "vue-router": "4.6.4",
    "vuex": "4.1.0"
  },
  "optionalDependencies": {
    "win-mouse": "1.3.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/register": "7.28.6",
    "@sentry/webpack-plugin": "5.4.0",
    "@types/chardet": "^0.5.0",
    "@types/clipboard": "^2.0.1",
    "@types/franc": "^4.0.0",
    "@types/fs-extra": "^7.0.0",
    "@types/lodash": "4.14.158",
    "@types/node": "24.10.1",
    "@types/os-locale": "^2.1.0",
    "@types/parse": "^2.9.0",
    "@electron/notarize": "3.1.1",
    "@sinonjs/fake-timers": "15.4.0",
    "@eslint/js": "9.39.5",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/compiler-sfc": "3.5.40",
    "@vue/compiler-dom": "3.5.40",
    "@vue/test-utils": "2.4.11",
    "babel-loader": "10.1.1",
    "cfonts": "^1.2.0",
    "chai": "^5.3.3",
    "chalk": "^2.4.1",
    "copy-webpack-plugin": "14.0.0",
    "cross-env": "^5.1.6",
    "css-loader": "7.1.4",
    "del": "^3.0.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "dotenv": "17.4.2",
    "electron-debug": "4.1.0",
    "eslint": "9.39.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-vue": "10.7.0",
    "fake-indexeddb": "6.2.5",
    "ffmpeg-ffprobe-static": "6.1.1",
    "globals": "17.7.0",
    "html-webpack-plugin": "5.6.7",
    "happy-dom": "20.11.0",
    "listr": "^0.14.3",
    "module-alias": "^2.0.6",
    "node-gyp": "6.0.0",
    "mini-css-extract-plugin": "2.10.2",
    "node-loader": "2.1.0",
    "path-browserify": "1.0.1",
    "querystring-es3": "0.2.1",
    "sass": "1.101.0",
    "sass-loader": "17.0.0",
    "sass-resources-loader": "2.2.5",
    "sinon": "22.0.0",
    "sinon-chai": "4.0.1",
    "source-map-support": "^0.5.9",
    "style-loader": "4.0.0",
    "svg-sprite-loader": "6.0.11",
    "terser-webpack-plugin": "5.3.16",
    "ts-loader": "9.6.2",
    "typescript": "5.9.3",
    "tslib": "2.8.1",
    "vue-eslint-parser": "10.4.1",
    "vite": "6.4.3",
    "vitest": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "vue-loader": "17.4.2",
    "vue-style-loader": "4.1.3",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1",
    "webpack-dev-server": "6.0.0",
    "webpack-hot-middleware": "^2.25.0"
  }
}
